# API
PORT=3001
HOST=0.0.0.0
# PostgreSQL connection (replaces MongoDB)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lamdis

# Auth0 (for JWT verification)
AUTH0_ISSUER=https://YOUR_DOMAIN/
AUTH0_AUDIENCE=https://api.lamdis.ai

# Auth0 Management API (Machine-to-Machine app)
# Create an M2M app in Auth0 Dashboard > Applications with following permissions:
# - read:users, update:users
# - read:organizations, create:organizations, update:organizations, delete:organizations
# - read:organization_members, create:organization_members, delete:organization_members
# - read:organization_invitations, create:organization_invitations, delete:organization_invitations
# - read:connections
AUTH0_DOMAIN=YOUR_TENANT.us.auth0.com
AUTH0_MGMT_CLIENT_ID=your_m2m_client_id
AUTH0_MGMT_CLIENT_SECRET=your_m2m_client_secret
# The connection ID of your default database connection (for enabling on orgs)
AUTH0_DEFAULT_CONNECTION_ID=con_xxxxxx
# Your Regular Web App client ID (used in invitations)
AUTH0_APP_CLIENT_ID=your_web_app_client_id

# Stripe
STRIPE_SECRET=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_ENTERPRISE=price_xxx
STRIPE_PRICE_INSIGHTS=price_xxx
STRIPE_PRICE_GROWTH=price_xxx
STRIPE_PRICE_SCALE=price_xxx
## Legacy (if migrating from old tiers)
# STRIPE_PRICE_SUCCESS=price_xxx
