## ─────────────────────────────────────────────────────────
## Lamdis Self-Hosted — Environment Variables
## ─────────────────────────────────────────────────────────
## Copy this file to .env and fill in your values.
##
## For zero-config local mode (no auth, no setup):
##   docker compose -f docker-compose.local.yml up -d
## ─────────────────────────────────────────────────────────

## ── Version ──────────────────────────────────────────────
## Pin to a specific release tag (e.g., 1.0.0). Default: latest
# LAMDIS_VERSION=latest

## ── Database ─────────────────────────────────────────────
POSTGRES_PASSWORD=changeme

## ── OIDC Authentication ──────────────────────────────────
## Configure your identity provider (Okta, Azure AD, Keycloak, etc.)
OIDC_ISSUER=https://your-idp.example.com
OIDC_CLIENT_ID=your-client-id
OIDC_AUDIENCE=lamdis

## Optional: override JWKS endpoint (auto-discovered from issuer by default)
# OIDC_JWKS_URI=https://your-idp.example.com/.well-known/jwks.json

## ── Bootstrap ────────────────────────────────────────────
## Token used for initial setup (POST /setup/bootstrap).
## Generate: openssl rand -hex 32
LAMDIS_ADMIN_TOKEN=

## ── Ports ────────────────────────────────────────────────
## Customize host ports if the defaults conflict.
# API_PORT=3001
# WEB_PORT=3000
# RUNS_PORT=3101
# POSTGRES_PORT=5432
# NATS_PORT=4222

## ── AWS Bedrock (for AI-powered evaluations) ─────────────
## Required for outcome evaluation and proof analysis.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
